# ============================================================
# Horizon 就两个配置文件：
#
#   本文件 .env            → 只管密钥
#   data/config.json       → 管 AI 模型、数据源、推送等
#
# 快速上手：
#   1. cp .env.example .env → 下面填 Key
#   2. 编辑 data/config.json → 改 provider 和 model
# ============================================================

# ============================================================
# AI 密钥（provider 用哪个就填哪个，只填一个就够了）
# ============================================================

# ----- 如果你 config.json 里 provider 选的 openai -----
OPENAI_API_KEY=sk-你的key

# ----- 如果你 config.json 里 provider 选的 28al（内置中转站）-----
# 填上面 OPENAI_API_KEY 即可，28al 也读这个变量

# ----- 如果你 config.json 里 provider 选的 anthropic -----
ANTHROPIC_API_KEY=sk-ant-你的key

# ----- 如果你 config.json 里 provider 选的 deepseek -----
DEEPSEEK_API_KEY=sk-你的key

# ----- 如果你 config.json 里 provider 选的 gemini -----
GOOGLE_API_KEY=你的key

# ----- 如果你 config.json 里 provider 选的 ali（通义千问）-----
DASHSCOPE_API_KEY=sk-你的key

# ----- 如果你 config.json 里 provider 选的 minimax -----
MINIMAX_API_KEY=你的key

# ----- 如果你 config.json 里 provider 选的 doubao（豆包）-----
DOUBAO_API_KEY=你的key

# ----- 如果你 config.json 里 provider 选的 azure -----
AZURE_OPENAI_API_KEY=你的key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# ============================================================
# 数据源 Token（按需填，不填也能跑）
# ============================================================

# GitHub Token — 强烈推荐，不填接口限流严重
GITHUB_TOKEN=ghp_你的token

# Twitter/X 抓取需要
# 获取地址：https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_你的token

# LWN.net 全文抓取需要
# 获取地址：https://lwn.net/  →  订阅后获取密钥
LWN_KEY=你的key

# ============================================================
# 通知推送（可选）
# ============================================================

# WebHook 地址 — 飞书/企业微信/Discord/Slack/Telegram 通用
HORIZON_WEBHOOK_URL=https://你的webhook地址

# 微信公众号发布
WECHAT_APPID=wx_你的appid
WECHAT_SECRET=你的secret

# QQ邮箱授权码 — 邮件订阅功能需要
EMAIL_PASSWORD=你的授权码

# ============================================================
# 高级选项（一般不用改）
# ============================================================

# HORIZON_PATH=/opt/Horizon
# HORIZON_OFFLINE=false
