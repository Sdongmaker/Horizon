# ============================================================
# Horizon 环境变量配置文件
# 复制此文件为 .env 后填写实际值：
#   cp .env.example .env
#
# 💡 已内置 28al 中转站 provider（28.al）：
#    config.json 中 provider 设为 "28al"，无需再配 base_url。
# ============================================================

# ----------------------------------------------------------
# AI 模型 API Key（至少配置一个）
# ----------------------------------------------------------

# Anthropic Claude（推荐，效果最佳）
# 申请地址：https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI GPT / o-series
# 申请地址：https://platform.openai.com/api-keys
# 同时被内置 28al 中转站 provider 使用
OPENAI_API_KEY=sk-xxx

# Azure OpenAI（微软 Azure 托管的 OpenAI 服务）
# 申请地址：Azure Portal → Azure OpenAI Service
# 如不使用 Azure，下面两行可删除
AZURE_OPENAI_API_KEY=xxx
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Google Gemini
# 申请地址：https://aistudio.google.com/apikey
GOOGLE_API_KEY=xxx

# MiniMax（国内模型）
# 申请地址：https://platform.minimaxi.com/user-center/basic-information/interface-key
MINIMAX_API_KEY=xxx

# 阿里云 DashScope（通义千问）
# 申请地址：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=xxx

# DeepSeek
# 申请地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=xxx

# 字节豆包
# 申请地址：https://console.volcengine.com/ark/region:ark+cn-beijing/apikey
DOUBAO_API_KEY=xxx

# ----------------------------------------------------------
# 外部数据源 Token
# ----------------------------------------------------------

# GitHub Personal Access Token（推荐填写，大幅提升 API 限额）
# 不填：60 次请求/小时
# 填写：5000 次请求/小时
# 申请地址：https://github.com/settings/tokens → 选 classic token，勾选 read:user
GITHUB_TOKEN=ghp_xxx

# Apify API Token（Twitter/X 数据抓取需要）
# 申请地址：https://console.apify.com/account/integrations
# 不使用 Twitter 抓取则可不填
APIFY_TOKEN=apify_api_xxx

# LWN.net 订阅密钥（Linux Weekly News 全文抓取需要）
# LWN 订阅用户可在 https://lwn.net/ 获取
# 不使用 LWN 抓取则可不填
LWN_KEY=xxx

# ----------------------------------------------------------
# 通知推送（可选）
# ----------------------------------------------------------

# WebHook 通知地址（用于将生成结果推送到企业微信/飞书/Discord/Slack 等）
# 支持平台: generic / feishu / dingtalk / wecom / discord / slack / telegram
HORIZON_WEBHOOK_URL=https://xxx

# ----------------------------------------------------------
# 微信公众号发布（可选）
# ----------------------------------------------------------

# 微信公众号 AppID
# 申请地址：微信公众平台 → 开发 → 基本配置
WECHAT_APPID=wx_xxx

# 微信公众号 AppSecret
WECHAT_SECRET=xxx

# ----------------------------------------------------------
# 邮箱发送（可选，用于邮件订阅功能）
# ----------------------------------------------------------

# QQ 邮箱授权码（如配置了 email 功能才需要）
# 获取方式：QQ邮箱 → 设置 → 账户 → POP3/SMTP服务 → 生成授权码
EMAIL_PASSWORD=xxx

# ----------------------------------------------------------
# MCP Server 相关（可选）
# ----------------------------------------------------------

# MCP Server 使用的密钥文件路径（密钥注入模式）
# 格式要求：键名须为纯大写+数字+下划线，例如 OPENAI_API_KEY
# 不填则自动从 .env 中读取
# HORIZON_MCP_SECRETS_PATH=/path/to/secrets.env

# Horizon 项目路径（MCP Server 需要，默认自动检测）
# HORIZON_PATH=/opt/Horizon

# 离线模式：设为 true/1/yes 则跳过 API 连通性检查
# HORIZON_OFFLINE=false
